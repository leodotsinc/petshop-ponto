# Banco de dados (Docker local)
POSTGRES_USER=ponto
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=ponto

# Usado pelo Next.js para conectar ao banco
DATABASE_URL=postgresql://ponto:troque-esta-senha@db:5432/ponto

# Segredo para assinar os tokens JWT — gere com: openssl rand -base64 48
JWT_SECRET=

# Senha inicial do painel admin (só usada na primeira execução das seeds)
ADMIN_INITIAL_PASSWORD=

# Nome da loja exibido no app
STORE_NAME=Pet Shop
